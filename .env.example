# ─── JWT Secrets ─────────────────────────────────────────────────────────────
# Generate with: openssl rand -hex 64
JWT_ACCESS_SECRET=change-me-access-secret-must-be-at-least-32-characters-long
JWT_REFRESH_SECRET=change-me-refresh-secret-must-be-at-least-32-characters-long

# ─── Internal Service Secret ──────────────────────────────────────────────────
# Used by API Gateway to call internal service endpoints
# Generate with: openssl rand -hex 32
INTERNAL_SERVICE_SECRET=change-me-internal-secret

# ─── Groq API (for AI Call Agent Whisper STT) ────────────────────────────────
# Free at: https://console.groq.com
GROQ_API_KEY=your-groq-api-key-here
