# ─── Server ───────────────────────────────────────────────
NODE_ENV=development
PORT=3000
SERVICE_NAME=api-gateway

# ─── Redis ────────────────────────────────────────────────
REDIS_URL=redis://default:password@host.redis-cloud.com:port

# ─── JWT ──────────────────────────────────────────────────
JWT_ACCESS_SECRET=same-secret-as-all-services-at-least-32-chars

# ─── Internal Secret ──────────────────────────────────────
INTERNAL_SERVICE_SECRET=same-internal-secret-as-all-services

# ─── Downstream Service URLs ──────────────────────────────
AUTH_SERVICE_URL=http://localhost:3001
INCIDENT_SERVICE_URL=http://localhost:3002
DISPATCH_SERVICE_URL=http://localhost:3003
ANALYTICS_SERVICE_URL=http://localhost:3004
AI_AGENT_SERVICE_URL=http://localhost:3005

# ─── CORS ─────────────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:3100,http://localhost:3000

# ─── Rate Limiting ────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=200
AUTH_RATE_LIMIT_MAX=20

# ─── Circuit Breaker ──────────────────────────────────────
# Number of consecutive failures before a service is marked as DOWN
CIRCUIT_BREAKER_THRESHOLD=5
# Seconds before attempting to reconnect to a downed service
CIRCUIT_BREAKER_RESET_SEC=30

# ─── Caching ──────────────────────────────────────────────
# TTL in seconds for cached GET responses (0 = disabled)
RESPONSE_CACHE_TTL=30
