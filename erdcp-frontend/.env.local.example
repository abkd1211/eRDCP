# API Gateway — all REST traffic goes through here
NEXT_PUBLIC_API_URL=http://localhost:3000

# Dispatch service — WebSocket connects directly for lower latency
NEXT_PUBLIC_DISPATCH_WS_URL=http://localhost:3003

# Mapbox — free token at account.mapbox.com (50k loads/month free)
NEXT_PUBLIC_MAPBOX_TOKEN=pk.your_mapbox_token_here
