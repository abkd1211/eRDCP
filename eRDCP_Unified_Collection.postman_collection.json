					"request": {
						"method": "POST",
						"header": [],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"name\": \"Kwame Mensah\",\n  \"email\": \"kwame@emergency.gh\",\n  \"password\": \"SecurePass123\",\n  \"role\": \"SYSTEM_ADMIN\"\n}",
							"options": {
								"raw": {
									"language": "json"
								}
							}
						},
						"url": {
							"raw": "{{baseUrl}}/auth/register",
