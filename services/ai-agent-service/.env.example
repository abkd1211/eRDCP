# ─── Server ───────────────────────────────────────────────
NODE_ENV=development
PORT=3005
SERVICE_NAME=ai-agent-service

# ─── MongoDB ──────────────────────────────────────────────
MONGODB_URI=mongodb+srv://user:password@cluster.mongodb.net/ai_agent_db?retryWrites=true&w=majority

# ─── Redis ────────────────────────────────────────────────
REDIS_URL=redis://default:password@host.redis-cloud.com:port

# ─── RabbitMQ ─────────────────────────────────────────────
RABBITMQ_URL=amqp://user:password@host.cloudamqp.com/vhost

# ─── JWT ──────────────────────────────────────────────────
JWT_ACCESS_SECRET=same-secret-as-other-services-at-least-32-chars

# ─── Incident Service (internal HTTP call to auto-submit) ─
INCIDENT_SERVICE_URL=http://localhost:3002
INTERNAL_SERVICE_SECRET=same-internal-secret-as-other-services

# ─── Whisper STT ──────────────────────────────────────────
# URL of your locally running Whisper API server
# Run with: docker run -p 9000:9000 onerahmet/openai-whisper-asr-webservice
WHISPER_API_URL=http://localhost:9000

# ─── NLP Settings ─────────────────────────────────────────
# Minimum confidence score to auto-submit without human review
AUTO_SUBMIT_CONFIDENCE_THRESHOLD=0.85
# Minimum confidence to even create an extraction (below this = discard)
MIN_EXTRACTION_CONFIDENCE=0.40

# ─── File Upload ──────────────────────────────────────────
MAX_AUDIO_FILE_SIZE_MB=25
AUDIO_UPLOAD_PATH=./uploads/audio

# ─── CORS ─────────────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3100

# ─── Rate Limiting ────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# ─── Nominatim Geocoding (free OpenStreetMap) ─────────────
NOMINATIM_URL=https://nominatim.openstreetmap.org
# Your app name for Nominatim's required User-Agent header
NOMINATIM_USER_AGENT=EmergencyResponsePlatform/1.0
