# ─── Server ───────────────────────────────────────────────
NODE_ENV=development
PORT=3004
SERVICE_NAME=analytics-service

# ─── MongoDB ──────────────────────────────────────────────
# Use direct connection string (not SRV) to avoid DNS issues
MONGODB_URI=mongodb://user:password@host1:27017,host2:27017,host3:27017/analytics_db?authSource=admin&replicaSet=atlas-xxx

# ─── Redis ────────────────────────────────────────────────
REDIS_URL=redis://default:password@host.redis-cloud.com:port

# ─── RabbitMQ ─────────────────────────────────────────────
RABBITMQ_URL=amqp://user:password@host.cloudamqp.com/vhost

# ─── JWT ──────────────────────────────────────────────────
JWT_ACCESS_SECRET=same-secret-as-other-services-at-least-32-chars

# ─── CORS ─────────────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3100

# ─── Rate Limiting ────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=200

# ─── Analytics Settings ───────────────────────────────────
# SLA target response time in seconds (default 8 minutes)
SLA_TARGET_SEC=480
# Cache TTL for dashboard snapshots in seconds
DASHBOARD_CACHE_TTL=60
