# ─── Server ───────────────────────────────────────────────
NODE_ENV=development
PORT=3003
SERVICE_NAME=dispatch-service

# ─── MongoDB ──────────────────────────────────────────────
MONGODB_URI=mongodb+srv://user:password@cluster.mongodb.net/dispatch_db?retryWrites=true&w=majority

# ─── Redis ────────────────────────────────────────────────
REDIS_URL=redis://default:password@host.redis-cloud.com:port

# ─── RabbitMQ ─────────────────────────────────────────────
RABBITMQ_URL=amqp://user:password@host.cloudamqp.com/vhost

# ─── JWT ──────────────────────────────────────────────────
JWT_ACCESS_SECRET=same-secret-as-auth-service-at-least-32-chars

# ─── CORS ─────────────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3100

# ─── Rate Limiting ────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=200

# ─── Dispatch Settings ────────────────────────────────────
# Max seconds between GPS pings before vehicle flagged as unresponsive
HEARTBEAT_TIMEOUT_SEC=120
# Max metres a vehicle can deviate from straight-line path before flagged
MAX_ROUTE_DEVIATION_METRES=500

# ─── Simulation ───────────────────────────────────────────────────────────────
# Mapbox token for road-following simulation (Directions API)
# If not set, falls back to straight-line interpolation
MAPBOX_TOKEN=pk.your_mapbox_token_here
