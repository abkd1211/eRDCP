# ─── Server ───────────────────────────────────────────────
NODE_ENV=development
PORT=3002
SERVICE_NAME=incident-service

# ─── Database ─────────────────────────────────────────────
DATABASE_URL="postgresql://incident_user:incident_password@localhost:5433/incident_db?schema=public"

# ─── Redis ────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ─── RabbitMQ ─────────────────────────────────────────────
RABBITMQ_URL=amqp://rmq_user:rmq_password@localhost:5672

# ─── JWT (same secret as auth service — for token verification) ───
JWT_ACCESS_SECRET=your-super-secret-access-key-change-in-production

# ─── Internal Service Communication ──────────────────────
AUTH_SERVICE_URL=http://localhost:3001
INTERNAL_SERVICE_SECRET=internal-service-secret-change-in-production

# ─── Rate Limiting ────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# ─── CORS ─────────────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3100
